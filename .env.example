# ═══════════════════════════════════════════════════════════
# HerdWatch Environment Configuration
# Copy this file to .env and fill in your actual credentials
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# Azure OpenAI Configuration (REQUIRED)
# ───────────────────────────────────────────────────────────
# Get these from your Azure OpenAI resource in Azure Portal

AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# ───────────────────────────────────────────────────────────
# Africa's Talking SMS Configuration (OPTIONAL)
# ───────────────────────────────────────────────────────────
# Leave blank to disable SMS features
# Get API key from: https://africastalking.com

AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=your-api-key-here

# ───────────────────────────────────────────────────────────
# Flask Configuration
# ───────────────────────────────────────────────────────────

FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ───────────────────────────────────────────────────────────
# CORS Configuration
# ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins

ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ───────────────────────────────────────────────────────────
# Video Analysis Configuration
# ───────────────────────────────────────────────────────────
# Seconds between frame analysis (default: 3)
# Lower = more frequent analysis (higher cost)
# Higher = less frequent analysis (lower cost)

FRAME_ANALYSIS_INTERVAL=3

# Path or filename of default video for analysis
VIDEO_SOURCE=cow.mp4

# ───────────────────────────────────────────────────────────
# Storage Configuration
# ───────────────────────────────────────────────────────────

# Path to SQLite database file
DB_PATH=herdwatch.db

# ───────────────────────────────────────────────────────────
# Logging Configuration
# ───────────────────────────────────────────────────────────

LOG_LEVEL=INFO
